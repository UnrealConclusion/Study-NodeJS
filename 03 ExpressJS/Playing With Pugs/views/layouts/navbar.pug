doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title #{title}
        link(rel="stylesheet", href="/css/styles.css")
    body 
        header 
            nav.navbar 
                ul
                    li: a(href='/', class=(page === 'home' ? 'active' : '')) Home
                    li: a(href='/add-pug', class=(page === 'pug' ? 'active' : '')) Add Pug 
        block content